# Server port (default 8080)
PORT=8080

# Feedback widget URLs — leave blank to hide the button in the UI
FEEDBACK_URL=https://your-feedback-form-url
ISSUE_URL=https://github.com/kmtz3/pbtoolkit/issues/new

# Session secret — MUST be set to a long random string in production
SESSION_SECRET=change-me-in-production

# OAuth 2.0 (optional — leave blank to disable the "Sign in with Productboard" button)
PB_OAUTH_CLIENT_ID=
PB_OAUTH_CLIENT_SECRET=
PB_OAUTH_REDIRECT_URI=https://yourapp.com/auth/pb/callback
